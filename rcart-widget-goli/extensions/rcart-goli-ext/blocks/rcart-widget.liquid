<link rel="stylesheet" href="{{ 'rcart-widget.css' | asset_url }}">

{%- comment -%} Hide the theme's page-title heading so the widget owns the full page. {%- endcomment -%}
<style>
  .main-page-title,
  .page-title,
  .template-page main .page-width > h1:first-child { display: none !important; }
</style>

<div
  id="rcart-widget-root"
  data-css-href="{{ 'rcart-widget.css' | asset_url }}"
  data-partner-code="{{ block.settings.partner_code }}"
  data-store-name="{{ block.settings.store_name | escape }}"
  data-api-url="{{ block.settings.api_url | escape }}"
  data-shop="{{ shop.permanent_domain }}"
  {% if block.settings.debug_mode %}data-debug-mode="true"{% endif %}
  data-fbpixel-src="{{ 'fbpixel.js' | asset_url }}"
  {% if block.settings.meta_pixel_id != blank %}data-meta-pixel-id="{{ block.settings.meta_pixel_id | escape }}"{% endif %}
  {% if customer %}data-email="{{ customer.email | escape }}"{% endif %}
  {% if customer %}data-user-id="{{ customer.id | escape }}"{% endif %}
  {% if block.settings.logo_url != blank %}data-logo-src="{{ block.settings.logo_url | image_url: width: 400 | escape }}"{% endif %}
  {% if block.settings.hero_image_url != blank %}data-hero-image-src="{{ block.settings.hero_image_url | image_url: width: 1400 | escape }}"{% endif %}
  data-step1-image="{% if block.settings.step_1_image_url != blank %}{{ block.settings.step_1_image_url | image_url: width: 800 }}{% else %}https://prod.withrcart.com/goli/step-1-bg.png{% endif %}"
  data-step2-image="{% if block.settings.step_2_image_url != blank %}{{ block.settings.step_2_image_url | image_url: width: 800 }}{% else %}https://prod.withrcart.com/goli/step-2-bg.png{% endif %}"
  data-step3-image="{% if block.settings.step_3_image_url != blank %}{{ block.settings.step_3_image_url | image_url: width: 800 }}{% else %}https://prod.withrcart.com/goli/step-3-bg.png{% endif %}"
></div>

<script src="{{ 'rcart-widget.js' | asset_url }}" defer></script>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    var el = document.getElementById('rcart-widget-root');
    if (el && window.mountRcartWidget) {
      window.mountRcartWidget(el);
    }
  });
  document.addEventListener('shopify:section:load', function(event) {
    var section = event.target;
    var el = section.querySelector('#rcart-widget-root');
    if (el && window.mountRcartWidget) {
      window.mountRcartWidget(el);
    }
  });
</script>

{% schema %}
{
  "name": "Rcart widget",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "partner_code",
      "label": "Partner code",
      "default": "goli"
    },
    {
      "type": "text",
      "id": "store_name",
      "label": "Store name",
      "default": "Goli"
    },
    {
      "type": "text",
      "id": "api_url",
      "label": "API URL",
      "info": "rcart API base URL, e.g. https://rcart-api.vercel.app",
      "default": "https://rcart-api.vercel.app"
    },
    {
      "type": "checkbox",
      "id": "debug_mode",
      "label": "Debug mode",
      "default": false,
      "info": "Shows a debug bar at the top of the widget with test controls and verbose console logging."
    },
    {
      "type": "text",
      "id": "meta_pixel_id",
      "label": "Meta Pixel ID",
      "info": "Optional. Overrides build-time VITE_FACEBOOK_PIXEL_ID when set. Visible in storefront HTML."
    },
    {
      "type": "image_picker",
      "id": "logo_url",
      "label": "Brand logo"
    },
    {
      "type": "image_picker",
      "id": "hero_image_url",
      "label": "Hero image"
    },
    {
      "type": "image_picker",
      "id": "step_1_image_url",
      "label": "Step 1 image"
    },
    {
      "type": "image_picker",
      "id": "step_2_image_url",
      "label": "Step 2 image"
    },
    {
      "type": "image_picker",
      "id": "step_3_image_url",
      "label": "Step 3 image"
    }
  ]
}
{% endschema %}
