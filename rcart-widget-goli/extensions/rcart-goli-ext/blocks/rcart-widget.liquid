<link rel="stylesheet" href="{{ 'rcart-widget.css' | asset_url }}">

<div
  id="rcart-widget-root"
  data-partner-code="{{ block.settings.partner_code }}"
  data-store-name="{{ block.settings.store_name | escape }}"
  data-api-url="{{ block.settings.api_url | escape }}"
  data-shop="{{ shop.permanent_domain }}"
  {% if block.settings.api_key != blank %}data-api-key="{{ block.settings.api_key | escape }}"{% endif %}
  data-fbpixel-src="{{ 'fbpixel.js' | asset_url }}"
  {% if block.settings.meta_pixel_id != blank %}data-meta-pixel-id="{{ block.settings.meta_pixel_id | escape }}"{% endif %}
  {% if block.settings.meta_access_token != blank %}data-meta-access-token="{{ block.settings.meta_access_token | escape }}"{% endif %}
  {% if customer %}data-email="{{ customer.email | escape }}"{% endif %}
  {% if customer %}data-user-id="{{ customer.id | escape }}"{% endif %}
  {% if block.settings.logo_url != blank %}data-logo-src="{{ block.settings.logo_url | image_url: width: 400 | escape }}"{% endif %}
  {% if block.settings.hero_image_url != blank %}data-hero-image-src="{{ block.settings.hero_image_url | image_url: width: 1400 | escape }}"{% endif %}
  {% if block.settings.step_1_image_url != blank %}data-step1-image="{{ block.settings.step_1_image_url | image_url: width: 800 | escape }}"{% endif %}
  {% if block.settings.step_2_image_url != blank %}data-step2-image="{{ block.settings.step_2_image_url | image_url: width: 800 | escape }}"{% endif %}
  {% if block.settings.step_3_image_url != blank %}data-step3-image="{{ block.settings.step_3_image_url | image_url: width: 800 | escape }}"{% endif %}
></div>

<script src="{{ 'rcart-widget.js' | asset_url }}" defer></script>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    var el = document.getElementById('rcart-widget-root');
    if (el && window.mountRcartWidget) {
      window.mountRcartWidget(el);
    }
  });
  document.addEventListener('shopify:section:load', function(event) {
    var section = event.target;
    var el = section.querySelector('#rcart-widget-root');
    if (el && window.mountRcartWidget) {
      window.mountRcartWidget(el);
    }
  });
</script>

{% schema %}
{
  "name": "Rcart widget",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "partner_code",
      "label": "Partner code",
      "default": "goli"
    },
    {
      "type": "text",
      "id": "store_name",
      "label": "Store name",
      "default": "Goli"
    },
    {
      "type": "text",
      "id": "api_url",
      "label": "API URL",
      "info": "rcart API base URL, e.g. https://rcart-api.vercel.app",
      "default": "https://rcart-api.vercel.app"
    },
    {
      "type": "text",
      "id": "api_key",
      "label": "API key",
      "info": "Sent as X-Api-Key on /api/discount. Visible in storefront HTML — prefer app embed secrets only when acceptable.",
      "default": "goli_dev_key_001"
    },
    {
      "type": "text",
      "id": "meta_pixel_id",
      "label": "Meta Pixel ID",
      "info": "Optional. Overrides build-time VITE_FACEBOOK_PIXEL_ID when set. Visible in storefront HTML."
    },
    {
      "type": "text",
      "id": "meta_access_token",
      "label": "Meta Access Token",
      "info": "Optional. Overrides build-time VITE_FACEBOOK_ACCESS_TOKEN for server-side / URL features. Visible in storefront HTML — use only if acceptable for your store."
    },
    {
      "type": "image_picker",
      "id": "logo_url",
      "label": "Brand logo"
    },
    {
      "type": "image_picker",
      "id": "hero_image_url",
      "label": "Hero image"
    },
    {
      "type": "image_picker",
      "id": "step_1_image_url",
      "label": "Step 1 image"
    },
    {
      "type": "image_picker",
      "id": "step_2_image_url",
      "label": "Step 2 image"
    },
    {
      "type": "image_picker",
      "id": "step_3_image_url",
      "label": "Step 3 image"
    }
  ]
}
{% endschema %}
